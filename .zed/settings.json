{
  "languages": {
    "C": {
      "tab_size": 2,
      "format_on_save": "on"
    }
  },
  "lsp": {
    "clangd": {}
  },
  "file_types": {
    "C": ["C", "H"]
  },
  "soft_wrap": "editor_width",
  "show_wrap_guides": true
  // "file_scan_inclusions": ["deps/**"]
}
